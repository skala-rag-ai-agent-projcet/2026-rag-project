<mxGraphModel>
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- 스타트업 탐색 에이전트 -->
    <mxCell id="2" value="스타트업 탐색 에이전트" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=14;shadow=1;" vertex="1" parent="1">
      <mxGeometry x="280" y="30" width="220" height="50" as="geometry"/>
    </mxCell>

    <!-- AI 심층 분석 그룹 박스 -->
    <mxCell id="3" value="" style="rounded=1;whiteSpace=wrap;fillColor=#E8EAF6;strokeColor=#3949AB;strokeWidth=2;dashed=1;opacity=40;" vertex="1" parent="1">
      <mxGeometry x="40" y="130" width="700" height="250" as="geometry"/>
    </mxCell>
    
    <!-- AI 심층 분석 라벨 -->
    <mxCell id="4" value="AI 심층 분석" style="text;html=1;fontSize=13;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#3949AB;align=left;" vertex="1" parent="1">
      <mxGeometry x="55" y="138" width="120" height="25" as="geometry"/>
    </mxCell>

    <!-- RAG 기반 근거 수집 -->
    <mxCell id="5" value="RAG 기반 근거 수집" style="rounded=1;whiteSpace=wrap;fillColor=#C5CAE9;strokeColor=#3949AB;fontStyle=1;fontSize=13;shadow=1;" vertex="1" parent="1">
      <mxGeometry x="280" y="175" width="220" height="45" as="geometry"/>
    </mxCell>

    <!-- 기술 분석 에이전트 -->
    <mxCell id="6" value="기술 분석&#xa;에이전트" style="rounded=1;whiteSpace=wrap;fillColor=#BBDEFB;strokeColor=#1565C0;fontStyle=1;fontSize=13;shadow=1;" vertex="1" parent="1">
      <mxGeometry x="70" y="280" width="160" height="50" as="geometry"/>
    </mxCell>

    <!-- 시장 및 정책 분석 에이전트 -->
    <mxCell id="7" value="시장 및 정책 분석&#xa;에이전트" style="rounded=1;whiteSpace=wrap;fillColor=#BBDEFB;strokeColor=#1565C0;fontStyle=1;fontSize=13;shadow=1;" vertex="1" parent="1">
      <mxGeometry x="310" y="280" width="160" height="50" as="geometry"/>
    </mxCell>

    <!-- 경쟁사 분석 에이전트 -->
    <mxCell id="8" value="경쟁사 분석&#xa;에이전트" style="rounded=1;whiteSpace=wrap;fillColor=#BBDEFB;strokeColor=#1565C0;fontStyle=1;fontSize=13;shadow=1;" vertex="1" parent="1">
      <mxGeometry x="550" y="280" width="160" height="50" as="geometry"/>
    </mxCell>

    <!-- 투자 판단 에이전트 -->
    <mxCell id="9" value="투자 판단 에이전트" style="rounded=1;whiteSpace=wrap;fillColor=#FFF9C4;strokeColor=#F9A825;fontStyle=1;fontSize=14;shadow=1;strokeWidth=2;" vertex="1" parent="1">
      <mxGeometry x="280" y="440" width="220" height="50" as="geometry"/>
    </mxCell>

    <!-- 투자 보고서 생성 -->
    <mxCell id="10" value="투자 보고서 생성" style="rounded=1;whiteSpace=wrap;fillColor=#C8E6C9;strokeColor=#2E7D32;fontStyle=1;fontSize=13;shadow=1;" vertex="1" parent="1">
      <mxGeometry x="120" y="560" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- 투자 검토 로그 기록 -->
    <mxCell id="11" value="투자 검토 로그 기록" style="rounded=1;whiteSpace=wrap;fillColor=#FFCDD2;strokeColor=#C62828;fontStyle=1;fontSize=13;shadow=1;" vertex="1" parent="1">
      <mxGeometry x="480" y="560" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- Edge: 스타트업 탐색 → RAG -->
    <mxCell id="20" style="endArrow=classic;strokeWidth=2;strokeColor=#555555;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="2" target="5" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Edge: RAG → 기술 분석 -->
    <mxCell id="21" style="endArrow=classic;strokeWidth=1.5;strokeColor=#3949AB;exitX=0.2;exitY=1;entryX=0.5;entryY=0;" edge="1" source="5" target="6" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Edge: RAG → 시장 정책 분석 -->
    <mxCell id="22" style="endArrow=classic;strokeWidth=1.5;strokeColor=#3949AB;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="5" target="7" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Edge: RAG → 경쟁사 분석 -->
    <mxCell id="23" style="endArrow=classic;strokeWidth=1.5;strokeColor=#3949AB;exitX=0.8;exitY=1;entryX=0.5;entryY=0;" edge="1" source="5" target="8" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Edge: 기술 분석 → 투자 판단 -->
    <mxCell id="24" style="endArrow=classic;strokeWidth=1.5;strokeColor=#555555;exitX=0.5;exitY=1;entryX=0.2;entryY=0;curved=1;" edge="1" source="6" target="9" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Edge: 시장 정책 → 투자 판단 -->
    <mxCell id="25" style="endArrow=classic;strokeWidth=1.5;strokeColor=#555555;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" source="7" target="9" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Edge: 경쟁사 → 투자 판단 -->
    <mxCell id="26" style="endArrow=classic;strokeWidth=1.5;strokeColor=#555555;exitX=0.5;exitY=1;entryX=0.8;entryY=0;curved=1;" edge="1" source="8" target="9" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Edge: 투자 판단 → 보고서 (투자 적합) -->
    <mxCell id="27" value="투자 적합" style="endArrow=classic;strokeWidth=2;strokeColor=#2E7D32;exitX=0.25;exitY=1;entryX=0.5;entryY=0;fontStyle=1;fontSize=11;fontColor=#2E7D32;labelBackgroundColor=#ffffff;" edge="1" source="9" target="10" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Edge: 투자 판단 → 로그 (보류/부적합) -->
    <mxCell id="28" value="보류 / 부적합" style="endArrow=classic;strokeWidth=2;strokeColor=#C62828;exitX=0.75;exitY=1;entryX=0.5;entryY=0;fontStyle=1;fontSize=11;fontColor=#C62828;labelBackgroundColor=#ffffff;" edge="1" source="9" target="11" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>